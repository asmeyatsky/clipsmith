# ============================================================
# Clipsmith Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values.
# Variables marked (REQUIRED) must be set for the app to run.
# Variables marked (OPTIONAL) have sensible defaults.

# ==================== Core ====================

# Environment mode: development, staging, production
# (OPTIONAL) Defaults to "development"
ENVIRONMENT=development

# ==================== JWT / Auth (REQUIRED) ====================
# Generate a secret: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE_ME_GENERATE_A_REAL_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# ==================== Database ====================
# (OPTIONAL) Defaults to SQLite for development
DATABASE_URL=sqlite:///database.db
# For production, use PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/clipsmith

# ==================== Stripe ====================
# (REQUIRED for payments) Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Webhook signing secret from https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=

# ==================== Storage ====================
# (OPTIONAL) Storage backend: local, s3, gcs. Defaults to "local"
STORAGE_TYPE=local
# Also accepted as: STORAGE_BACKEND=local

# Local storage settings
UPLOAD_DIR=./uploads
THUMBNAIL_DIR=./thumbnails
STORAGE_BASE_URL=http://localhost:8000/uploads

# AWS S3 Configuration (required if STORAGE_TYPE=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=
# Alternative name (also accepted):
# AWS_BUCKET_NAME=
CLOUDFRONT_DOMAIN=
# For testing with local S3-compatible services (MinIO, LocalStack):
# AWS_ENDPOINT_URL=http://localhost:9000

# Google Cloud Storage Configuration (required if STORAGE_TYPE=gcs)
GCS_BUCKET_NAME=
GCS_PROJECT_ID=
# Path to service account key JSON (or use Application Default Credentials):
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GCS_CDN_DOMAIN=

# ==================== Redis ====================
# (OPTIONAL) Full Redis URL. Takes precedence over REDIS_HOST/REDIS_PORT.
# Falls back to in-memory when unavailable in development.
REDIS_URL=redis://localhost:6379
# Legacy individual settings (used if REDIS_URL is not set):
REDIS_HOST=localhost
REDIS_PORT=6379

# ==================== AssemblyAI ====================
# (REQUIRED for caption generation) Get key from https://www.assemblyai.com/
# In development, leave blank or set to "your-assemblyai-api-key" for placeholder captions.
ASSEMBLYAI_API_KEY=

# ==================== CORS ====================
# (OPTIONAL) Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000

# ==================== Email (SMTP) ====================
# (OPTIONAL) Leave SMTP_HOST empty to use console logging in development
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# FROM_EMAIL=noreply@clipsmith.com
# SMTP_USE_TLS=true

# ==================== Frontend ====================
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ==================== Internal ====================
# Used by background workers to access video files
BACKEND_URL=http://localhost:8000

# Allowed redirect hosts for OAuth/payment return URLs
# ALLOWED_REDIRECT_HOSTS=localhost,clipsmith.com,www.clipsmith.com
